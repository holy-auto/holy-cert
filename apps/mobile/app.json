{
  "expo": {
    "name": "Ledra",
    "slug": "ledra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ledra",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ledra.app",
      "infoPlist": {
        "NFCReaderUsageDescription": "Ledraは証明書NFCタグの読み取りと書き込みに使用します",
        "NSCameraUsageDescription": "Ledraは施工写真の撮影に使用します",
        "NSLocationWhenInUseUsageDescription": "Stripe Terminal の利用に位置情報が必要です",
        "NSBluetoothAlwaysUsageDescription": "将来のカードリーダー接続にBluetoothを使用します"
      },
      "entitlements": {
        "com.apple.developer.proximity-reader.payment.acceptance": true
      }
    },
    "android": {
      "package": "com.ledra.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.NFC",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "5d5394bd-6242-48ef-9e36-3151e0d3dc8a"
      },
      "router": {}
    },
    "owner": "ledra",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@stripe/stripe-terminal-react-native",
        {
          "bluetoothBackgroundMode": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Ledraは施工写真の撮影に使用します"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ledraは施工写真の選択に使用します"
        }
      ]
    ]
  }
}
