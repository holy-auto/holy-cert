# ============================================================
# CARTRUST 環境変数テンプレート
# このファイルを .env.local にコピーして値を設定してください
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Connect Webhook（加盟店・代理店向け Transfer/Payout/ApplicationFee イベント）
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_xxx

# テナントプラン Price ID（月額）
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PRO=price_xxx

# テナントプラン Price ID（年額・20%OFF）
STRIPE_PRICE_STARTER_ANNUAL=price_xxx
STRIPE_PRICE_STANDARD_ANNUAL=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx

# 旧 mini プラン互換（既存サブスクリプションの webhook 処理用）
STRIPE_PRICE_MINI=price_xxx

# ─── キャンペーン ─────────────────────────────────────────
# 初期100店舗キャンペーン Coupon ID（Stripeダッシュボードで作成、プランごと）
STRIPE_COUPON_LAUNCH_100_STANDARD=campaign_launch_100_standard
STRIPE_COUPON_LAUNCH_100_PRO=campaign_launch_100_Pro
CAMPAIGN_LAUNCH_100_MAX_SLOTS=100

# テンプレートオプション Price ID
STRIPE_PRICE_TEMPLATE_PRESET_SETUP=price_xxx
STRIPE_PRICE_TEMPLATE_PRESET_MONTHLY=price_xxx
STRIPE_PRICE_TEMPLATE_CUSTOM_SETUP=price_xxx
STRIPE_PRICE_TEMPLATE_CUSTOM_MONTHLY=price_xxx

# 保険会社プラン Price ID
STRIPE_INSURER_PRICE_BASIC=price_xxx
STRIPE_INSURER_PRICE_PRO=price_xxx
STRIPE_INSURER_PRICE_ENTERPRISE=price_xxx

# ─── メール (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM=noreply@cartrust.co.jp

# 問い合わせフォーム
CONTACT_FROM_EMAIL=noreply@cartrust.co.jp
CONTACT_TO_EMAIL=info@cartrust.co.jp

# ─── Upstash QStash ────────────────────────────────────────
QSTASH_TOKEN=xxx
QSTASH_CURRENT_SIGNING_KEY=sig_xxx
QSTASH_NEXT_SIGNING_KEY=sig_xxx

# ─── Upstash Redis (レート制限) ────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── Google Calendar 連携 ──────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPx-xxx
GOOGLE_REDIRECT_URI=https://app.cartrust.co.jp/api/admin/gcal/callback

# ─── Cron ジョブ認証 ───────────────────────────────────────
CRON_SECRET=your-random-secret-here

# ─── 顧客認証 ──────────────────────────────────────────────
CUSTOMER_AUTH_PEPPER=your-random-pepper-here

# ─── 課金 ──────────────────────────────────────────────────
# トライアル終了後のグレース期間（日数）
BILLING_GRACE_DAYS=7

# ─── Sentry ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=sntrys_xxx

# ─── Claude AI (Anthropic) — 車検証OCR ────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── アプリ URL ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.cartrust.co.jp
NEXT_PUBLIC_BASE_URL=https://app.cartrust.co.jp
NEXT_PUBLIC_SITE_URL=https://cartrust.co.jp
NEXT_PUBLIC_LOGIN_URL=https://app.cartrust.co.jp/login
NEXT_PUBLIC_CONTACT_EMAIL=info@cartrust.co.jp
