# ============================================================
# CARTRUST 環境変数テンプレート
# このファイルを .env.local にコピーして値を設定してください
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...
# Optional read replica (Supabase Pro). When set and distinct from
# NEXT_PUBLIC_SUPABASE_URL, anonymous public reads (e.g. /v/[vin]) and
# /api/health route to the replica. Lag is typically <1s.
# Setup: docs/disaster-recovery.md
SUPABASE_REPLICA_URL=

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Connect Webhook（加盟店・代理店向け Transfer/Payout/ApplicationFee イベント）
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_xxx

# テナントプラン Price ID（月額）
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PRO=price_xxx

# テナントプラン Price ID（年額・20%OFF）
STRIPE_PRICE_STARTER_ANNUAL=price_xxx
STRIPE_PRICE_STANDARD_ANNUAL=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx

# 旧 mini プラン互換（既存サブスクリプションの webhook 処理用）
STRIPE_PRICE_MINI=price_xxx

# ─── キャンペーン ─────────────────────────────────────────
# 初期100店舗キャンペーン Coupon ID（Stripeダッシュボードで作成、プランごと）
STRIPE_COUPON_LAUNCH_100_STANDARD=campaign_launch_100_standard
STRIPE_COUPON_LAUNCH_100_PRO=campaign_launch_100_Pro
CAMPAIGN_LAUNCH_100_MAX_SLOTS=100

# テンプレートオプション Price ID
STRIPE_PRICE_TEMPLATE_PRESET_SETUP=price_xxx
STRIPE_PRICE_TEMPLATE_PRESET_MONTHLY=price_xxx
STRIPE_PRICE_TEMPLATE_CUSTOM_SETUP=price_xxx
STRIPE_PRICE_TEMPLATE_CUSTOM_MONTHLY=price_xxx

# 保険会社プラン Price ID
STRIPE_INSURER_PRICE_BASIC=price_xxx
STRIPE_INSURER_PRICE_PRO=price_xxx
STRIPE_INSURER_PRICE_ENTERPRISE=price_xxx

# ─── メール (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM=noreply@cartrust.co.jp

# 問い合わせフォーム
CONTACT_FROM_EMAIL=noreply@cartrust.co.jp
CONTACT_TO_EMAIL=info@cartrust.co.jp

# リード自動返信メールの From（未設定時は RESEND_FROM を使用）
LEAD_REPLY_FROM_EMAIL=Ledra <noreply@ledra.co.jp>

# ─── Marketing Lead Capture ───────────────────────────────
# Slack Incoming Webhook — マーケリード着信通知
SLACK_LEADS_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ─── Platform Inquiry Slack Notifications ─────────────────
# プラットフォーム内の問い合わせフォームからの通知先（用途ごとに別Webhook）
# 未設定なら通知はスキップされる（開発／プレビュー環境では未設定可）
SLACK_ADMIN_SUPPORT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
SLACK_AGENT_SUPPORT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
SLACK_CUSTOMER_INQUIRY_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# 新規施工店（テナント）登録通知
SLACK_SIGNUP_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ─── Analytics (PostHog) ──────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Upstash QStash ────────────────────────────────────────
QSTASH_TOKEN=xxx
QSTASH_CURRENT_SIGNING_KEY=sig_xxx
QSTASH_NEXT_SIGNING_KEY=sig_xxx

# ─── Upstash Redis (レート制限) ────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── Google Calendar 連携 ──────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPx-xxx
GOOGLE_REDIRECT_URI=https://app.cartrust.co.jp/api/admin/gcal/callback

# ─── Cron ジョブ認証 ───────────────────────────────────────
CRON_SECRET=your-random-secret-here

# ─── 顧客認証 ──────────────────────────────────────────────
# 32 文字以上のランダム文字列。生成例:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CUSTOMER_AUTH_PEPPER=your-random-pepper-here

# ─── セキュリティイベントログのソルト ────────────────────
# IP / ユーザー識別子をハッシュ化してログに残す際のソルト。
# 設定しない場合はデフォルト値が使われるが、本番では必ず固有値を設定すること。
SECURITY_LOG_SALT=your-random-salt-here

# ─── レート制限の挙動 ────────────────────────────────────
# Redis (Upstash) が落ちた場合の挙動を制御する。
#   1 = fail-closed (503 を返してリクエストを拒否) — 高セキュリティ環境向け
#   未設定 / その他 = fail-open (Sentry 通報のみで通過) — デフォルト
# PoC / 企業連携で DDoS 耐性を最優先する場合は 1 を推奨。
RATE_LIMIT_FAIL_CLOSED=0

# ─── テナント機微情報の at-rest 暗号化 ─────────────────────
# Square OAuth tokens / LINE channel secret などを DB 保存前に
# AES-256-GCM で暗号化するための鍵 (base64 エンコードされた 32 バイト)。
# 生成例:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 紛失すると暗号化済み列が復号できなくなるため、安全に保管・rotation すること。
SECRET_ENCRYPTION_KEY=your-base64-32-byte-key-here

# ─── 課金 ──────────────────────────────────────────────────
# トライアル終了後のグレース期間（日数）
BILLING_GRACE_DAYS=7

# ─── Sentry ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=sntrys_xxx

# ─── Claude AI (Anthropic) — 車検証OCR ────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── アプリ URL ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.cartrust.co.jp
NEXT_PUBLIC_BASE_URL=https://app.cartrust.co.jp
NEXT_PUBLIC_SITE_URL=https://cartrust.co.jp
NEXT_PUBLIC_LOGIN_URL=https://app.cartrust.co.jp/login
NEXT_PUBLIC_CONTACT_EMAIL=info@cartrust.co.jp

# ─── Twilio (SMS) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=xxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=xxx

# ─── gBizINFO (Corporate Number Lookup) ───────────────────
GBIZ_API_KEY=xxx

# ─── Digital Signature ────────────────────────────────────
LEDRA_SIGNING_PRIVATE_KEY=xxx
LEDRA_SIGNING_PUBLIC_KEY=xxx
LEDRA_SIGNING_KEY_VERSION=1

# ─── Customer Portal ──────────────────────────────────────
CUSTOMER_PORTAL_GLOBAL_AUTH_PEPPER=xxx

# ─── Signature Session ────────────────────────────────────
SIGNATURE_SESSION_EXPIRES_HOURS=24
NEXT_PUBLIC_SIGN_BASE_URL=https://app.cartrust.co.jp/sign
NEXT_PUBLIC_VERIFY_BASE_URL=https://app.cartrust.co.jp/verify

# ─── Platform ─────────────────────────────────────────────
PLATFORM_TENANT_ID=xxx

# ─── App URL ──────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Polygon Anchoring (署名ウォレット) ───────────────────
# 詳細なセットアップ手順は docs/metamask-signer-setup.md を参照
# 本番/Staging は Vercel の環境変数に登録し、そこから `vercel env pull .env.local` で手元に反映する運用
#
# DEFAULT: 新規発行のデフォルトでアンカリングを ON にする方針 (docs/ledra-goals-strategy-2026-05.md §9 #2)。
# - ローカル / staging では amoy testnet (無料) のため安全に有効化できる。
# - 本番 mainnet 利用時は POLYGON_PRIVATE_KEY / POLYGON_CONTRACT_ADDRESS_POLYGON / POLYGON_NETWORK=polygon
#   を Vercel env で必ず設定すること。未設定だと anchorToPolygon() が安全側に no-op で返る (DISABLED_RESULT)。
POLYGON_ANCHOR_ENABLED=true
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# 署名専用のアカウントを MetaMask で新規作成し、その秘密鍵を設定する（資産用メインアカウントを使わないこと）
POLYGON_PRIVATE_KEY=0xyour-signer-private-key
POLYGON_CONTRACT_ADDRESS=0xyour-anchor-contract-address
# 'mainnet' | 'amoy' (testnet)
POLYGON_NETWORK=amoy
# ウォレット残高の警告しきい値 (MATIC) — cron/polygon-signer が CONTACT_TO_EMAIL へ通知
POLYGON_WALLET_WARN_BALANCE_POL=1.0
POLYGON_WALLET_ALERT_BALANCE_POL=0.2

# ─── C2PA / IPFS (証明書改ざん検知 / anchoring) ─────────────
# disabled | dev-signed | production
C2PA_MODE=disabled
# production モード時のみ必要 (PEM 形式)
C2PA_SIGNER_CERT=
C2PA_SIGNER_KEY=
# Pinata JWT (IPFS pinning) — 未設定時は IPFS pin をスキップ
PINATA_JWT=

# ─── Deepfake / 画像検知 ──────────────────────────────────
# 'hive' などのプロバイダ名、未設定なら無効化
DEEPFAKE_PROVIDER=
HIVE_API_KEY=

# ─── Device Attestation ───────────────────────────────────
# 'true' | 'false'
DEVICE_ATTESTATION_ENABLED=false

# ─── Square (POS 連携 / 任意) ─────────────────────────────
# /api/cron/square-sync と /api/square/webhook で使用
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=

# ─── 会計ソフト連携 (freee / マネーフォワード) ─────────────
# /admin/accounting および /api/cron/accounting-sync で使用。
# freee: https://app.secure.freee.co.jp/developers
# 加盟店が初回 1 回だけ OAuth 認可すれば、以降は自動で売上仕訳が freee に投入される。
FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=

# マネーフォワード (パートナー審査通過後に値が入る)
# https://biz.moneyforward.com/partner
# MF_SCOPES は審査時に申請したスコープ文字列を空白区切りで設定
MF_CLIENT_ID=
MF_CLIENT_SECRET=
MF_SCOPES=

# ─── Resend Webhook (bounce / complaint 取り込み) ─────────
RESEND_WEBHOOK_SECRET=

# ─── Marketing ページの「累計」統計の最小表示値 ──────────
# 証明書/店舗の実件数が少ない初期は見栄え用にフロアを設定
NEXT_PUBLIC_MARKETING_STATS_MIN_CERT=0
NEXT_PUBLIC_MARKETING_STATS_MIN_SHOP=0
