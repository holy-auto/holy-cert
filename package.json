{
  "name": "holy-cert",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:migrations": "node scripts/lint-migrations.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "prepare": "husky",
    "demo:setup": "tsx scripts/setup-demo-agent.ts",
    "demo:setup-insurer": "tsx scripts/setup-demo-insurer.ts",
    "demo:setup-tenant": "tsx scripts/setup-demo-tenant.ts",
    "demo:setup-tenant-user": "tsx scripts/setup-demo-tenant-user.ts",
    "demo:reset-tenant": "tsx scripts/setup-demo-tenant.ts --reset",
    "video:studio": "remotion studio remotion/index.tsx",
    "video:render": "remotion render remotion/index.tsx LedraIntro out/LedraIntro.mp4",
    "screenshots:capture": "tsx scripts/capture-screenshots.ts"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --no-warn-ignored"
    ],
    "src/**/*.{json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@contentauth/c2pa-node": "^0.5.4",
    "@googleapis/calendar": "^14.2.0",
    "@peculiar/webcrypto": "^1.5.0",
    "@peculiar/x509": "^2.0.0",
    "@react-pdf/renderer": "^4.5.1",
    "@remotion/cli": "^4.0.454",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.98.0",
    "@upstash/qstash": "^2.10.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.22.0",
    "cheerio": "^1.2.0",
    "driver.js": "^1.4.0",
    "ethers": "^6.16.0",
    "exifr": "^7.1.3",
    "google-auth-library": "^10.6.2",
    "import-in-the-middle": "^3.0.1",
    "jszip": "^3.10.1",
    "next": "^16.2.4",
    "next-intl": "^4.9.2",
    "posthog-js": "^1.372.3",
    "qrcode": "^1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "remotion": "^4.0.454",
    "require-in-the-middle": "^8.0.1",
    "resend": "^6.10.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "swr": "^2.4.1",
    "viem": "^2.48.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.5"
  }
}
