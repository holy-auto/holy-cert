# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# vercel
.vercel

# claude code worktrees (prevents Tailwind/Turbopack from scanning symlinks)
.claude/

# typescript
*.tsbuildinfo

# Local backup files created by patch scripts
*.bak_*

_backup/


# backups
*.bak.*

# temp clip patch
scripts/_clip_patch.ps1
scripts/_clip_patch*.ps1

.vercel
