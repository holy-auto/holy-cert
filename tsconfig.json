{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@ledra/contracts": [
        "./packages/contracts/src/index.ts"
      ],
      "@ledra/contracts/*": [
        "./packages/contracts/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.mts",
    "packages/contracts/src/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "*.ts",
    "*.mts"
  ],
  "exclude": [
    "node_modules",
    "_backup",
    "_diag",
    "apps"
  ]
}
